{
  "name": "customerlist",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "npx kill-port 3001 5173",
    "dev": "concurrently \"nodemon --experimental-sqlite server.js\" \"npm run dev --prefix client\"",
    "server": "nodemon --experimental-sqlite server.js",
    "client": "npm run dev --prefix client",
    "install:all": "npm install && npm install --prefix client",
    "build": "npm run build --prefix client",
    "start": "node --experimental-sqlite server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.14"
  }
}
